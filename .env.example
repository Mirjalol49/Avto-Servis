DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# Preferred current Supabase API keys:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
# Legacy fallback keys are still supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXTAUTH_SECRET="generated-secret"
NEXTAUTH_URL="http://localhost:3000"
CURRENCY="UZS"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_NAME="Admin"
# Set true only when intentionally resetting an existing admin password.
ADMIN_RESET_PASSWORD="false"
